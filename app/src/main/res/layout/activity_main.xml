<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1f1f1f"
        android:text="Smart Pantry – Mars"
        android:textAlignment="center"
        android:padding="14dp"
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="#fccd49" />

    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:queryHint="Szukaj produktu..."
        android:background="#1f1f1f"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:iconifiedByDefault="false"
        app:queryBackground="@android:color/transparent" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        app:singleLine="false"
        app:singleSelection="false"
        app:chipSpacing="6dp"
        app:chipSpacingHorizontal="6dp"
        app:chipSpacingVertical="6dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wszystkie"
            app:chipBackgroundColor="#6B4EFF"
            app:chipStrokeColor="#FFFFFF"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipDry"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sypkie"
            app:chipBackgroundColor="#6B4EFF" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSpices"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Przyprawy"
            app:chipBackgroundColor="#6B4EFF" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipOils"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oleje"
            app:chipBackgroundColor="#6B4EFF" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipCans"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Konserwy"
            app:chipBackgroundColor="#6B4EFF" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipBreakfast"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Śniadaniowe"
            app:chipBackgroundColor="#6B4EFF" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipDairy"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nabiał"
            app:chipBackgroundColor="#6B4EFF" />

    </com.google.android.material.chip.ChipGroup>

    <ListView
        android:id="@+id/listViewItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:padding="8dp" />

</LinearLayout>